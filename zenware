local function openFrame(buttonClone)
	local frame = mainScreenUI:FindFirstChild(buttonClone.Name)
	frame.Visible = not frame.Visible

	local newColor
	if frame.Visible == true then
		newColor = Color3.fromRGB(78, 173, 73)
	else
		newColor = Color3.fromRGB(255, 255, 255)
	end

	buttonClone:SetAttribute("BaseTextColor", newColor)

	local currentHoverColor = getHoverColor(newColor)
	TweenService:Create(buttonClone, tweenInfo, {TextColor3 = currentHoverColor}):Play()
end

