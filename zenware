-----------------------------------
-- 2. Targeting Logic (Updated)
-----------------------------------
local function getClosestTarget()
    local closestTarget = nil
    local shortestDistance = math.huge
    local myChar = LocalPlayer.Character
    
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then 
        return nil 
    end
    
    local myPos = myChar.HumanoidRootPart.Position

    -- 2A. Check for Real Players
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            -- Optional: Add a health check here if you want to avoid hitting dead players
            local targetPos = player.Character.HumanoidRootPart.Position
            local distance = (targetPos - myPos).Magnitude
            
            if distance < shortestDistance then
                shortestDistance = distance
                closestTarget = player.Character -- Returning the Character Model
            end
        end
    end
    
    -- 2B. Check for Dummies/NPCs in Workspace
    for _, obj in pairs(workspace:GetDescendants()) do
        -- string.lower ensures it catches "Dummy", "DUMMY", "dummies", etc.
        if obj:IsA("Model") and string.find(string.lower(obj.Name), "dummy") then
            if obj:FindFirstChild("HumanoidRootPart") then
                local targetPos = obj.HumanoidRootPart.Position
                local distance = (targetPos - myPos).Magnitude
                
                if distance < shortestDistance then
                    shortestDistance = distance
                    closestTarget = obj -- Returning the Dummy Model
                end
            end
        end
    end
    
    return closestTarget
end

-----------------------------------
-- 3. Toggle & Attack Loop (Updated)
-----------------------------------
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.Q then
        toggled = not toggled
        
        Title.Text = toggled and "Auto Attack [Q]: ON" or "Auto Attack [Q]: OFF"
        Title.TextColor3 = toggled and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 100, 100)
        
        if toggled then
            task.spawn(function()
                while toggled do
                    -- Now grabs a Model (Player Character or Dummy)
                    local targetModel = getClosestTarget() 
                    local myChar = LocalPlayer.Character
                    
                    if targetModel and myChar and myChar:FindFirstChild("HumanoidRootPart") and targetModel:FindFirstChild("HumanoidRootPart") then
                        
                        local startPos = myChar.HumanoidRootPart.Position
                        local targetPos = targetModel.HumanoidRootPart.Position

                        -- Direction to target
                        local aimDirection = (targetPos - startPos).Unit

                        -- Position 28 studs forward toward target
                        local fakePosition = startPos + (aimDirection * 20)
                        
                        local args = {
                            [1] = {
                                ["clientTime"] = workspace:GetServerTimeNow(), 
                                ["direction"] = aimDirection,
                                ["position"] = fakePosition
                            }
                        }
                        
                        pcall(function()
                            RemoteEvent:FireServer(unpack(args))
                        end)
                    end
                    
                    task.wait(hitDelay)
                end
            end)
        end
    end
end)
