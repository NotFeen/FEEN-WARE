local function applyTransparencyEffect(guiObject)
	local hoverTween = TweenService:Create(guiObject, transparencyTweenInfo, {BackgroundTransparency = 0})
	local leaveTween = TweenService:Create(guiObject, transparencyTweenInfo, {BackgroundTransparency = 1})

	local isHovering = false

	guiObject.MouseMoved:Connect(function()
		if not isHovering then
			isHovering = true
			leaveTween:Cancel()
			hoverTween:Play()
		end
	end)

	guiObject.MouseLeave:Connect(function()
		if isHovering then
			isHovering = false
			hoverTween:Cancel()
			leaveTween:Play()
		end
	end)
end


