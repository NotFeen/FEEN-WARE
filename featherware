		uiCorner(bSlider, 4)

		local wheelBtn = Instance.new("TextButton", cFrame)
		wheelBtn.Size = UDim2.new(0.08, 0, 0.5, 0)
		wheelBtn.Position = UDim2.new(0.90, 0, 0.25, 0)
		wheelBtn.BackgroundColor3 = defaultColor
		wheelBtn.Text = ""
		uiCorner(wheelBtn, 4)

		local btnStroke = Instance.new("UIStroke", wheelBtn)
		btnStroke.Color = Color3.fromRGB(200, 200, 200)
		btnStroke.Thickness = 1

		local mainTargetGui = (settingsCont and settingsCont:FindFirstAncestorOfClass("ScreenGui")) 
			or game:GetService("CoreGui"):FindFirstChildOfClass("ScreenGui") 
			or game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui"):FindFirstChildOfClass("ScreenGui") 
			or settingsCont

		local wheelPopup = Instance.new("Frame", mainTargetGui)
		wheelPopup.Size = UDim2.new(0, 160, 0, 190)
