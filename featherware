		wheelImage.Size = UDim2.new(0, 130, 0, 130)
		wheelImage.Position = UDim2.new(0.5, -65, 0, 30)
		wheelImage.BackgroundTransparency = 1
		wheelImage.Image = "rbxassetid://2849458409" 
		wheelImage.ZIndex = 10

		local wheelPin = Instance.new("Frame", wheelImage)
		wheelPin.Size = UDim2.new(0, 6, 0, 6)
		wheelPin.AnchorPoint = Vector2.new(0.5, 0.5)
		wheelPin.BackgroundColor3 = Color3.new(1, 1, 1)
		wheelPin.ZIndex = 11
		uiCorner(wheelPin, 3)

		local pinStroke = Instance.new("UIStroke", wheelPin)
		pinStroke.Color = Color3.new(0, 0, 0)
		pinStroke.Thickness = 1

		if cCallback then cCallback(defaultColor) end

		local function updateColor()
			local r = math.clamp(tonumber(rSlider.Text) or math.floor(defaultColor.R * 255), 0, 255)
			local g = math.clamp(tonumber(gSlider.Text) or math.floor(defaultColor.G * 255), 0, 255)
			local b = math.clamp(tonumber(bSlider.Text) or math.floor(defaultColor.B * 255), 0, 255)

			r = math.floor(r)
			g = math.floor(g)
			b = math.floor(b)

			rSlider.Text = tostring(r)
			gSlider.Text = tostring(g)
			bSlider.Text = tostring(b)

			local finalColor = Color3.fromRGB(r, g, b)

			mod.Values[cName] = finalColor

			_G.SavedConfig[settingID] = {
				R = r,
				G = g,
				B = b
			}

			saveConfigToPC()

			wheelBtn.BackgroundColor3 = finalColor

			if cCallback then
				cCallback(finalColor)
			end

			if mod.Callbacks.OnValueChanged then
				mod.Callbacks.OnValueChanged(cName, finalColor)
			end
		end

		local isDragging = false

		local function updateFromWheel(input)
			local rSize = wheelImage.AbsoluteSize
			local rPos = wheelImage.AbsolutePosition
			local mousePos = input.Position

			local relativeX = mousePos.X - (rPos.X + rSize.X / 2)
			local relativeY = mousePos.Y - (rPos.Y + rSize.Y / 2)

			local angle = math.atan2(relativeY, relativeX)
			local hue = (angle + math.pi) / (2 * math.pi)

			local radius = rSize.X / 2
			local distance = math.sqrt(relativeX^2 + relativeY^2)
			local saturation = math.clamp(distance / radius, 0, 1)

			if distance > radius then
				relativeX = (relativeX / distance) * radius
				relativeY = (relativeY / distance) * radius
			end

			wheelPin.Position = UDim2.new(0.5, relativeX, 0.5, relativeY)

			local pickedColor = Color3.fromHSV(hue, saturation, 1)
			rSlider.Text = tostring(math.floor(pickedColor.R * 255))
			gSlider.Text = tostring(math.floor(pickedColor.G * 255))
			bSlider.Text = tostring(math.floor(pickedColor.B * 255))

			updateColor()
		end

		local function syncPinPosition()
			local r = tonumber(rSlider.Text) or 255
			local g = tonumber(gSlider.Text) or 255
			local b = tonumber(bSlider.Text) or 255
			local h, s, v = Color3.fromRGB(r, g, b):ToHSV()

			local angle = (h * 2 * math.pi) - math.pi
			local radius = (wheelImage.AbsoluteSize.X / 2) * s

			wheelPin.Position = UDim2.new(0.5, math.cos(angle) * radius, 0.5, math.sin(angle) * radius)
		end

		mod.UpdateFunctions[cName] = function(forceColor)
			rSlider.Text = tostring(math.floor(forceColor.R * 255))
			gSlider.Text = tostring(math.floor(forceColor.G * 255))
			bSlider.Text = tostring(math.floor(forceColor.B * 255))
			updateColor()
		end

		wheelBtn.MouseButton1Click:Connect(function()
			wheelPopup.Visible = not wheelPopup.Visible
			if wheelPopup.Visible then
				syncPinPosition()
			end
		end)

		closeWheel.MouseButton1Click:Connect(function()
			wheelPopup.Visible = false
		end)

		wheelImage.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				isDragging = true
				updateFromWheel(input)
			end
		end)

		UserInputService.InputChanged:Connect(function(input)
			if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
				updateFromWheel(input)
			end
		end)

		UserInputService.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				isDragging = false
			end
		end)

		rSlider.FocusLost:Connect(updateColor)
		gSlider.FocusLost:Connect(updateColor)
		bSlider.FocusLost:Connect(updateColor)
	end
end

