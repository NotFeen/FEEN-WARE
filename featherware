local function processChatQueue()
	if queueActive then return end
	queueActive = true

	task.spawn(function()
		-- Safe evaluation using standard loops to prevent memory locks
		while #chatQueue > 0 do
			local messageToSend = table.remove(chatQueue, 1)

			if messageToSend and messageToSend ~= "" then
				local TextChatService = game:GetService("TextChatService")
				if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
					local rbxGeneral = TextChatService:FindFirstChild("TextChannels") and TextChatService.TextChannels:FindFirstChild("RBXGeneral")
					if rbxGeneral then
						rbxGeneral:SendAsync(messageToSend)
					end
				else
					-- FIXED: Re-written cleanly to remove hidden invalid formatting characters
					local chatEvents = game:GetService("ReplicatedStorage"):FindFirstChild("DefaultChatSystemChatEvents")
					local sayMessageRequest = chatEvents and chatEvents:FindFirstChild("SayMessageRequest")
					if sayMessageRequest then
						sayMessageRequest:FireServer(messageToSend, "All")
					end
				end
			end

			task.wait(2.5)
		end
		queueActive = false
	end)
end

local function queueLocalChat(rawMessage, victimPlayer, fallbackString)
	if not rawMessage or rawMessage == "" then return end

	local uName = victimPlayer and victimPlayer.Name or (fallbackString or "everyone")
	local dName = victimPlayer and victimPlayer.DisplayName or (fallbackString or "everyone")

	local formatted = rawMessage
	formatted = string.gsub(formatted, "{username}", uName)
	formatted = string.gsub(formatted, "{user}", uName)
	formatted = string.gsub(formatted, "{displayname}", dName)
	formatted = string.gsub(formatted, "{display}", dName)

	table.insert(chatQueue, formatted)
	processChatQueue()
end

