RunService.Heartbeat:Connect(function()

	-- CLIMBER
	if loops["climber"] then
		now = os.clock()

		if now - lastRaycast >= raycastDelay then
			lastRaycast = now

			char = cachedChar
			hrp = cachedHRP
			humanoid = cachedHumanoid

			if char and hrp and humanoid and humanoid.Health > 0 then

				local moveDir = humanoid.MoveDirection

				if moveDir.Magnitude > 0 then

					if not raycastParams then
						raycastParams = RaycastParams.new()
						raycastParams.FilterType = Enum.RaycastFilterType.Exclude
						raycastParams.IgnoreWater = true
					end

					raycastParams.FilterDescendantsInstances = {char}

					local forwardRay = workspace:Raycast(
						hrp.Position,
						moveDir * 2.5,
						raycastParams
					)

					if forwardRay then
						local part = forwardRay.Instance

						if part and part.CanCollide then

							local hitModel = part:FindFirstAncestorOfClass("Model")

							if not (hitModel and hitModel:FindFirstChildOfClass("Humanoid")) then

								local climbSpeed = tonumber(ClimbButton.Values["Climb Speed"]) or 35

								if ClimbButton.Values["Force Climb State"] then
									humanoid:ChangeState(Enum.HumanoidStateType.Climbing)
								end

								local velocity = hrp.AssemblyLinearVelocity

								hrp.AssemblyLinearVelocity = Vector3.new(
									velocity.X,
									climbSpeed,
									velocity.Z
								)
							end
						end
					end
				end
			end
		end
	end


	-- INFINITE JUMP
	if loops["infinite jump"] then

		if not UserInputService:IsKeyDown(Enum.KeyCode.Space) then
			consecutiveJumps = 0

		elseif not isGPE then

			if isGPE then return end

			local hrp = cachedHRP
			local humanoid = cachedHumanoid

			if hrp and humanoid and humanoid.Health > 0 then

				local now = os.clock()
				local cooldown = tonumber(InfJump.Values["Jump Cooldown"]) or 0.1

				if now - lastJumpTime >= cooldown then

					if now - lastJumpTime < cooldown + 1 then
						consecutiveJumps += 1
					else
						consecutiveJumps = 0
					end

					lastJumpTime = now

					local nativePower = humanoid.UseJumpPower 
						and humanoid.JumpPower 
						or 50

					local accel = tonumber(InfJump.Values["Jump Accel (per jump)"]) or 0

					local finalPower = nativePower + (consecutiveJumps * accel)

					if InfJump.Values["Bypass Jump Limits"] then
						humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
					end

					local velocity = hrp.AssemblyLinearVelocity

					hrp.AssemblyLinearVelocity = Vector3.new(
						velocity.X,
						finalPower,
						velocity.Z
					)
				end
			end
		end
	end

	if loops["phase"] then

		local char = cachedChar
		local hrp = cachedHRP
		local humanoid = cachedHumanoid

		if char and hrp and humanoid and humanoid.Health > 0 then

			local method = PhaseButton.Values["Phase Method"]

			if method == "Noclip" then

				for i = 1, #phaseParts do
					local part = phaseParts[i]

					if part and part.CanCollide then
						part.CanCollide = false
					end
				end


			elseif method == "Forward Push" then

				local moveDir = humanoid.MoveDirection

				if moveDir.Magnitude > 0 then

					phaseRaycastParams.FilterDescendantsInstances = {char}

					local forwardRay = workspace:Raycast(
						hrp.Position,
						moveDir * 2,
						phaseRaycastParams
					)

					if forwardRay and forwardRay.Instance and forwardRay.Instance.CanCollide then

						local depth = tonumber(PhaseButton.Values["Push Depth"]) or 1.5

						hrp.CFrame = hrp.CFrame + (moveDir * depth)
					end
				end
			end
		end
	end

end)

local function isInFOV(myHRP, targetHRP, maxAngle)
	local forward = myHRP.CFrame.LookVector
	local toTarget = (targetHRP.Position - myHRP.Position).Unit

	local dot = forward:Dot(toTarget)

	local angle = math.deg((math.acos(math.clamp(dot, -1, 1))))

	return angle <= maxAngle
end

local function faceTarget(characterA, characterB)
	local hrpA = characterA:FindFirstChild("HumanoidRootPart")
	local hrpB = characterB:FindFirstChild("HumanoidRootPart")

	if hrpA and hrpB then
		local lookPosition = Vector3.new(hrpB.Position.X, hrpA.Position.Y, hrpB.Position.Z)
		hrpA.CFrame = CFrame.lookAt(hrpA.Position, lookPosition)
	end
end


