local function isValidTarget(model)
	-- 1. Basic safety checks
	if not model or not model:IsA("Model") or model == Player.Character then 
		return false 
	end

	-- 2. Component checks (Must have a Humanoid and HumanoidRootPart)
	local humanoid = model:FindFirstChildOfClass("Humanoid")
	local hrp = model:FindFirstChild("HumanoidRootPart")
	if not humanoid or not hrp or humanoid.Health <= 0 then 
		return false 
	end

	-- 3. Check if it's a real Player
	local targetPlayer = Players:GetPlayerFromCharacter(model)
	if targetPlayer then
		-- Exclude teammates
		if targetPlayer.Team == Player.Team then 
			return false 
		end

		-- Exclude spectators (Checks if their team name contains "Spectator")
		if targetPlayer.Team and string.find(targetPlayer.Team.Name:lower(), "spectator") then
			return false
		end

		return true -- Valid enemy player!
	end

	-- 4. Check if it's a valid Dummy (Name must end with "Dummy")
	-- Using :lower() makes it work for both "Dummy" and "dummy"
	if string.match(model.Name:lower(), "dummy$") then
		return true -- Valid dummy!
	end

	-- If it's not a valid player and not a dummy, it's an NPC -> Ignore it
	return false
end

-- 1. Scan for the target nearest to the MOUSE
local function getTargetNearMouse()
	local mousePos = UserInputService:GetMouseLocation()
	local nearestHRP = nil
	local shortestDist = BowLock.Values["FOV"]

	-- Scans the workspace for valid targets
	for _, obj in ipairs(workspace:GetDescendants()) do 
		if isValidTarget(obj) then
			local hrp = obj:FindFirstChild("HumanoidRootPart")
			local screenPos, onScreen = camera:WorldToViewportPoint(hrp.Position)

			if onScreen then
				local dist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude

				if dist < shortestDist then
					shortestDist = dist
					nearestHRP = hrp
				end
			end
		end
	end

	return nearestHRP
end

-- 2. Handle the Camera Glide (With Drop Compensation)
local function startTracking()
	-- Prevent tracking from starting if the toggle is set to false
	if not loops["bow lock"] then return end
	if trackingConnection then return end

	activeTarget = getTargetNearMouse()

	if activeTarget then
		trackingConnection = RunService.RenderStepped:Connect(function()
			-- Break the lock if the toggle is turned off, or if the target becomes invalid
			if not loops["bow lock"] or not activeTarget or not activeTarget.Parent or not isValidTarget(activeTarget.Parent) then
				stopTracking()
				return
			end

			-- Calculate the distance between the camera and the target
			distance = (activeTarget.Position - camera.CFrame.Position).Magnitude

			-- Drop compensation math
			timeToTarget = distance / 240
			dropCompensation = 0.5 * 36 * (timeToTarget ^ 2)

			-- Aim slightly above the HRP (chest/head level) PLUS the drop compensation
			targetPosition = activeTarget.Position + Vector3.new(0, 1 + dropCompensation, 0)

			-- Calculate where the camera WANTS to look
			goalCFrame = CFrame.lookAt(camera.CFrame.Position, targetPosition)

			-- Glide the camera towards the goal smoothly
			camera.CFrame = camera.CFrame:Lerp(goalCFrame, BowLock.Values["Smoothness"])
		end)
	end
end

local function stopTracking()
	if trackingConnection then
		trackingConnection:Disconnect()
		trackingConnection = nil
	end
	activeTarget = nil
end

