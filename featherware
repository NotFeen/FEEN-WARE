local function generateRandomString(length)
	local chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
	local result = ""
	for i = 1, length do
		local rand = math.random(1, #chars)
		result = result .. string.sub(chars, rand, rand)
	end
	return result
end

