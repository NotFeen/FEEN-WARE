	function mod:CreateDropdown(dName, options, default, dCallback, multiSelect, isPlayerDropdown)
		multiSelect = multiSelect or false
		local settingID = uniquePrefix .. "_" .. dName
		local favSettingID = settingID .. "_Favs"

		if isPlayerDropdown then
			options = {}
			for _, p in ipairs(Players:GetPlayers()) do
				table.insert(options, p.Name)
			end
		end

		if _G.SavedConfig[settingID] ~= nil then
			default = _G.SavedConfig[settingID]
		else
			_G.SavedConfig[settingID] = default
		end

		if _G.SavedConfig[favSettingID] == nil then
			_G.SavedConfig[favSettingID] = {}
		end
		local favorites = _G.SavedConfig[favSettingID]

		if multiSelect then
			if type(default) == "table" then
				mod.Values[dName] = {}
				for _, v in ipairs(default) do table.insert(mod.Values[dName], v) end
			else
				mod.Values[dName] = default and {default} or {}
			end
		else
			mod.Values[dName] = default
		end

		local dropCont = Instance.new("Frame", settingsCont)
		dropCont.BackgroundTransparency = 1
		dropCont.AutomaticSize = Enum.AutomaticSize.Y
		dropCont.Size = UDim2.new(1, 0, 0, 0)
		local dLayout = Instance.new("UIListLayout", dropCont)
		dLayout.SortOrder = Enum.SortOrder.LayoutOrder

		local dBtn = Instance.new("TextButton", dropCont)
		dBtn.Size = UDim2.new(1, 0, 0, 28)
		dBtn.BackgroundTransparency = 1
		dBtn.TextColor3 = Color3.fromRGB(180, 180, 180)
		dBtn.TextXAlignment = Enum.TextXAlignment.Left
		dBtn.TextSize = 20
		dBtn.FontFace = Font.fromName(textFont)
		dBtn.LayoutOrder = 1

		local optFrame = Instance.new("ScrollingFrame", dropCont)
		optFrame.BackgroundTransparency = 1
		optFrame.Size = UDim2.new(1, 0, 0, 240)
		optFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
		optFrame.AutomaticCanvasSize = "Y"
		optFrame.ScrollBarThickness = 4
		optFrame.ScrollBarImageColor3 = Color3.fromRGB(100, 100, 100)
		optFrame.Visible = false
		optFrame.LayoutOrder = 2

		local oLayout = Instance.new("UIListLayout", optFrame)
		oLayout.SortOrder = Enum.SortOrder.LayoutOrder

		local function updateDropdownText()
			if multiSelect then
				local count = #mod.Values[dName]
				if count == 0 then
					dBtn.Text = "      - " .. dName .. ": None"
				elseif count == 1 then
					dBtn.Text = "      - " .. dName .. ": " .. tostring(mod.Values[dName][1])
				else
					dBtn.Text = "      - " .. dName .. ": [" .. count .. " Selected]"
				end
			else
				local val = mod.Values[dName]
				dBtn.Text = "      - " .. dName .. ": " .. (val ~= nil and tostring(val) or "None")
			end
		end

		updateDropdownText() 
		if dCallback then dCallback(mod.Values[dName]) end

		local fullyPopulated = false

		local function buildOptions()
			for _, child in ipairs(optFrame:GetChildren()) do
				if child:IsA("Frame") then
					child:Destroy()
				end
			end

			for i, opt in ipairs(options) do
				if i % 100 == 0 then task.wait() end

				local optKey = tostring(opt)

				local row = Instance.new("Frame", optFrame)
				row.Size = UDim2.new(1, 0, 0, 24)
				row.BackgroundTransparency = 1

				local oBtn = Instance.new("TextButton", row)
				oBtn.Size = UDim2.new(1, -35, 1, 0)
				oBtn.BackgroundTransparency = 1
				oBtn.TextColor3 = Color3.fromRGB(120, 120, 120)
				oBtn.TextXAlignment = Enum.TextXAlignment.Left
				oBtn.TextSize = 18
				oBtn.FontFace = Font.fromName(textFont)

				local favBtn = Instance.new("TextButton", row)
				favBtn.Size = UDim2.new(0, 24, 0, 24)
				favBtn.Position = UDim2.new(1, -28, 0, 0)
				favBtn.BackgroundTransparency = 1
				favBtn.TextSize = 16
				favBtn.FontFace = Font.fromName(textFont)

				local function updateVisual()
					if multiSelect then
						local isSelected = table.find(mod.Values[dName], opt)
						oBtn.Text = (isSelected and "          > [x] " or "          > [ ] ") .. optKey
						oBtn.TextColor3 = isSelected and Color3.new(1,1,1) or Color3.fromRGB(120, 120, 120)
					else
						oBtn.Text = "          > " .. optKey
					end
				end

				local function updateFavSort()
					local isFav = favorites[optKey] == true
					row.LayoutOrder = isFav and i or (10000 + i)
					favBtn.Text = isFav and "★" or "☆"
					favBtn.TextColor3 = isFav and Color3.fromRGB(254, 204, 34) or Color3.fromRGB(80, 80, 80)
				end

				updateVisual() 
				updateFavSort()

				oBtn.MouseEnter:Connect(function() 
					tween(oBtn, {TextColor3 = Color3.new(1,1,1)}) 
				end)

				oBtn.MouseLeave:Connect(function() 
					if multiSelect and table.find(mod.Values[dName], opt) then return end
					tween(oBtn, {TextColor3 = Color3.fromRGB(120, 120, 120)}) 
				end)

				favBtn.MouseEnter:Connect(function()
					if not favorites[optKey] then favBtn.TextColor3 = Color3.fromRGB(200, 200, 200) end
				end)

				favBtn.MouseLeave:Connect(function()
					if not favorites[optKey] then favBtn.TextColor3 = Color3.fromRGB(80, 80, 80) end
				end)

				favBtn.MouseButton1Click:Connect(function()
					favorites[optKey] = not favorites[optKey] or nil
					_G.SavedConfig[favSettingID] = favorites
					saveConfigToPC()
					updateFavSort()
				end)

				oBtn.MouseButton1Click:Connect(function()
					if multiSelect then
						local foundIdx = table.find(mod.Values[dName], opt)
						if foundIdx then
							table.remove(mod.Values[dName], foundIdx)
						else
							table.insert(mod.Values[dName], opt)
						end

						updateVisual()
						updateDropdownText()

						_G.SavedConfig[settingID] = mod.Values[dName]
						saveConfigToPC()

						if dCallback then dCallback(mod.Values[dName]) end
						if mod.Callbacks.OnValueChanged then mod.Callbacks.OnValueChanged(dName, mod.Values[dName]) end
					else
						optFrame.Visible = false
						mod.Values[dName] = opt

						updateDropdownText()

						_G.SavedConfig[settingID] = opt
						saveConfigToPC()

						if dCallback then dCallback(opt) end
						if mod.Callbacks.OnValueChanged then mod.Callbacks.OnValueChanged(dName, opt) end
					end
				end)
			end
		end
		mod.UpdateFunctions[dName] = function(forceVal)
			mod.Values[dName] = forceVal
			_G.SavedConfig[settingID] = forceVal
			saveConfigToPC()
			updateDropdownText()
			if dCallback then dCallback(forceVal) end
			if mod.Callbacks.OnValueChanged then mod.Callbacks.OnValueChanged(dName, forceVal) end
		end


		dBtn.MouseButton1Click:Connect(function() 
			optFrame.Visible = not optFrame.Visible 

			if optFrame.Visible and not fullyPopulated then
				fullyPopulated = true
				buildOptions()
			end
		end)

		if isPlayerDropdown then
			local pAdded = Players.PlayerAdded:Connect(function(plr)
				if not table.find(options, plr.Name) then
					table.insert(options, plr.Name)
					if fullyPopulated then buildOptions() end
				end
			end)

			local pRemoving = Players.PlayerRemoving:Connect(function(plr)
				local idx = table.find(options, plr.Name)
				if idx then
					table.remove(options, idx)
					if fullyPopulated then buildOptions() end
				end

				if multiSelect then
					local selIdx = table.find(mod.Values[dName], plr.Name)
					if selIdx then
						table.remove(mod.Values[dName], selIdx)
						updateDropdownText()
						if dCallback then dCallback(mod.Values[dName]) end
					end
				else
					if mod.Values[dName] == plr.Name then
						mod.Values[dName] = nil
						updateDropdownText()
						if dCallback then dCallback(nil) end
					end
				end
			end)

			dropCont.Destroying:Connect(function()
				pAdded:Disconnect()
				pRemoving:Disconnect()
			end)
		end
	end

	function mod:CreateKeybind(kName, defaultKey, kCallback)
		local settingID = uniquePrefix .. "_" .. kName

		if _G.SavedConfig[settingID] ~= nil then
			local savedEnumName = _G.SavedConfig[settingID]
			defaultKey = savedEnumName and Enum.KeyCode[savedEnumName] or nil
		else
			_G.SavedConfig[settingID] = defaultKey and defaultKey.Name or nil
		end

		local kBtn = Instance.new("TextButton", settingsCont)
		kBtn.Size = UDim2.new(1, 0, 0, 28)
		kBtn.BackgroundTransparency = 1
		local keyString = defaultKey and defaultKey.Name or "None"
		kBtn.Text = "      - " .. kName .. ": [" .. keyString .. "]"
		kBtn.TextColor3 = Color3.fromRGB(180, 180, 180)
		kBtn.TextXAlignment = Enum.TextXAlignment.Left
		kBtn.TextSize = 20
		kBtn.FontFace = Font.fromName(textFont)

		if kCallback then kCallback(defaultKey) end

		local waiting = false
		kBtn.MouseButton1Click:Connect(function()
			waiting = true
			_G.IsBindingKey = true
			kBtn.Text = "      - " .. kName .. ": [...]"
			kBtn.TextColor3 = Color3.fromRGB(220, 220, 220)
		end)

		UserInputService.InputBegan:Connect(function(input, GPE)
			if waiting and input.UserInputType == Enum.UserInputType.Keyboard then
				waiting = false
				local key = input.KeyCode
				if key == Enum.KeyCode.Backspace or key == Enum.KeyCode.Escape then key = nil end

				kBtn.Text = "      - " .. kName .. ": [" .. (key and key.Name or "None") .. "]"
				kBtn.TextColor3 = Color3.fromRGB(180, 180, 180)

				_G.SavedConfig[settingID] = key and key.Name or nil
				saveConfigToPC()

				if kCallback then kCallback(key) end
				task.defer(function() _G.IsBindingKey = false end)
			end
		end)
	end

