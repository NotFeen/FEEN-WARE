local function getBestEquippedSword(playerName)
	inventories = replicatedStorage:FindFirstChild("Inventories")
	if not inventories then return nil end

	playerInv = inventories:FindFirstChild(playerName)
	if not playerInv then return nil end

	bestSword = nil
	highestScore = -1

	for _, item in ipairs(playerInv:GetChildren()) do
		local score = weaponTiers[item.Name]

		if score and score > highestScore then
			highestScore = score
			bestSword = item.Name
		end
	end

	return bestSword
end

local function applySkin(viewmodel, item)
	if not item or typeof(item) ~= "Instance" then return end
	if not viewmodel then return end

	-- Sword check
	local isSword = false
	for _, swordName in ipairs(swords) do
		if string.lower(item.Name) == string.lower(swordName) then
			isSword = true
			break
		end
	end

	if not isSword then return end
	if not loops["sword skin changer"] then return end

	local handle = item:FindFirstChild("Handle")
	if not handle then return end

	-- Remove old skin
	local oldSkin = viewmodel:FindFirstChild(item.Name .. "_Skin")
	if oldSkin then
		oldSkin:Destroy()
	end

	-- Find skin
	local targetSkinName = string.lower(item.Name .. "_" .. currentSelectedSkin)
	local replacementItem = itemsFolder and itemsFolder:FindFirstChild(targetSkinName)

	if not replacementItem then
		return
	end

	local skinHandle = replacementItem:FindFirstChild("Handle")
	if not skinHandle then
		return
	end

	-- Create skin model
	local skinModel = Instance.new("Model")
	skinModel.Name = item.Name .. "_Skin"
	skinModel.Parent = viewmodel

	local skin = skinHandle:Clone()
	skin.Parent = skinModel

	skin.Anchored = false
	skin.CanCollide = false
	skin.Massless = true

	local offset = skinOffsets[currentSelectedSkin] or CFrame.new()
	skin.CFrame = handle.CFrame * offset

	local weld = Instance.new("WeldConstraint")
	weld.Part0 = handle
	weld.Part1 = skin
	weld.Parent = skin

	-- Only hide original after skin exists
	for _, v in ipairs(item:GetDescendants()) do
		if v:IsA("BasePart") then
			v.Transparency = 1
			v.LocalTransparencyModifier = 1
		elseif v:IsA("ParticleEmitter") or v:IsA("Trail") then
			v.Enabled = false
		end
	end
end

