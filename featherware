-- Configuration
FLY_UP_SPEED = Fly.Values["Fly Speed"]   -- How fast you go up/down
BYPASS_INTERVAL = Fly.Values["Bypass Interval"]   -- How often to trigger the anticheat bypass (in seconds)

lastBypassTime = os.clock()
isBypassing = false

-- Helper to safely get character elements
function getCharacterData()
	char = cachedChar
	if not char then return nil end

	hrp = cachedHRP
	hum = cachedHumanoid

	if hrp and hum and hum.Health > 0 then
		return char, hrp, hum
	end
	return nil
end

function startFlying()
	char, hrp, hum = getCharacterData()
	if not hrp then return end

	-- Lift the player off the ground slightly to prevent floor friction bugs
	hrp.CFrame = hrp.CFrame + Vector3.new(0, 0.1, 0)
	hum:ChangeState(Enum.HumanoidStateType.Freefall)

	bodyVelocity = Instance.new("BodyVelocity")
	bodyVelocity.Name = "VerticalFlyForce"

	-- TRICK: We only lock the Y-axis (Vertical). 
	-- This allows Roblox's physics engine to handle WASD walking naturally in the air!
	bodyVelocity.MaxForce = Vector3.new(0, 9e9, 0) 
	bodyVelocity.Velocity = Vector3.new(0, 0, 0)
	bodyVelocity.Parent = hrp

	lastBypassTime = os.clock()
	isBypassing = false

	-- Setup Raycast parameters for the ground check
	rayParams = RaycastParams.new()
	rayParams.FilterDescendantsInstances = {char}
	rayParams.FilterType = Enum.RaycastFilterType.Exclude

	-- Connect to frame updates
	flyConnection = RunService.Heartbeat:Connect(function()
		currentChar, currentHrp, currentHum = getCharacterData()

		-- Auto-clean if player dies or despawns
		if not currentHrp or not currentHum then
			stopFlying()
			return
		end

		-- Keep bodyVelocity inside the RootPart
		if bodyVelocity.Parent ~= currentHrp then
			bodyVelocity.Parent = currentHrp
		end

		-- 1. Anti-Cheat Drop Bypass (Every 1.5 seconds)
		if os.clock() - lastBypassTime >= Fly.Values["Bypass Interval"] and not isBypassing then

			-- RAYCAST: Check distance to the ground
			rayResult = workspace:Raycast(currentHrp.Position, Vector3.new(0, -15, 0), rayParams)
			distToGround = rayResult and (currentHrp.Position.Y - rayResult.Position.Y) or 999

			if distToGround > 4 then
				isBypassing = true
				task.spawn(function()
					-- Initial check just in case
					if not bodyVelocity then return end

					bodyVelocity.Velocity = Vector3.new(0, -35, 0)
					task.wait(0.03) -- Fall for 30ms

					if not bodyVelocity then 
						isBypassing = false
						return 
					end

					bodyVelocity.Velocity = Vector3.new(0, 45, 0)
					task.wait(0.05) -- Pull up for 50ms

					if not bodyVelocity then 
						isBypassing = false
						return 
					end

					-- Resume normal hover
					bodyVelocity.Velocity = Vector3.new(0, 0, 0)
					lastBypassTime = os.clock()
					isBypassing = false
				end)
			else
				lastBypassTime = os.clock()
			end
		end

		-- 2. Handle Fly Inputs (Only when not bypassing)
		if not isBypassing then
			targetYVelocity = 0

			-- Correctly check if the user is typing in chat/UI
			isTyping = UserInputService:GetFocusedTextBox() ~= nil

			if not isTyping then
				if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
					targetYVelocity = Fly.Values["Fly Speed"]
				end
				if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
					targetYVelocity = -Fly.Values["Fly Speed"]
				end
			end

			bodyVelocity.Velocity = Vector3.new(0, targetYVelocity, 0)
		end
	end)
end

function stopFlying()
	if flyConnection then
		flyConnection:Disconnect()
		flyConnection = nil
	end
	if bodyVelocity then
		bodyVelocity:Destroy()
		bodyVelocity = nil
	end
end

