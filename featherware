local function applyESP(model, isNPC)
	if not model or not model.Parent then return end
	clearESP(model) -- Clear any old instances to prevent duplicates on respawn

	local espOnOwn = ESP.Values["ESP On Own Player"]
	local espOnNPCs = ESP.Values["ESP On NPCs"]
	local isOwnPlayer = model == Player.Character

	local ownerPlayer = Players:GetPlayerFromCharacter(model)

	if ownerPlayer 
		and ownerPlayer ~= Player
		and ownerPlayer.Team == Player.Team then

		return
	end

	if isOwnPlayer and not espOnOwn then return end
	if isNPC and not espOnNPCs then return end

	-- Initialize tracking array for this specific entity model
	activeESP[model] = {}

	-- 1. CHAMS HANDLER
	if ESP.Values["Chams"] then
		local highlight = Instance.new("Highlight")
		highlight.FillColor = ESP.Values["Chams Color"] or Color3.new(0.333333, 0, 0.498039)
		highlight.FillTransparency = 0.5 
		highlight.OutlineColor = Color3.new(1, 1, 1)
		highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		highlight.Adornee = model
		highlight.Parent = chamsESPFolder

		table.insert(activeESP[model], highlight) -- Track it
	end

	-- 2. 3D BOX HANDLER
	if ESP.Values["3D Box"] then
		local hrp = model:FindFirstChild("HumanoidRootPart") or model.PrimaryPart
		if hrp then
			local espBOX = Instance.new("Part")
			espBOX.Name = "3D_ESP_BOX"
			espBOX.Anchored = false
			espBOX.CanCollide = false
			espBOX.Color = ESP.Values["3D Box Color"] or Color3.new(0.333333, 0, 0.498039)
			espBOX.Transparency = 0.65
			espBOX.Material = Enum.Material.SmoothPlastic
			espBOX.Size = Vector3.new(4, 5, 2)
			espBOX.CFrame = hrp.CFrame
			espBOX.Parent = model

			local weld = Instance.new("WeldConstraint")
			weld.Part0 = espBOX
			weld.Part1 = hrp
			weld.Parent = espBOX

			table.insert(activeESP[model], espBOX) -- Track it
		end
	end

	-- 3. 2D BOX HANDLER (UPGRADED VISUALS)
	if ESP.Values["2D Box"] then
		local frame = Instance.new("Frame")
		frame.BackgroundColor3 = Color3.new(0, 0, 0)
		frame.BackgroundTransparency = 0.85 -- Slight dark fill for depth
		frame.BorderSizePixel = 0
		frame.Size = UDim2.fromOffset(0, 0)
		frame.Visible = false
		frame.Parent = espScreenGui
		frame.ZIndex = 10

		-- Modern slightly rounded corners
		local corner = Instance.new("UICorner")
		corner.CornerRadius = UDim.new(0, 2)
		corner.Parent = frame

		-- Outer black stroke for high visibility on bright backgrounds
		local outerStroke = Instance.new("UIStroke")
		outerStroke.Color = Color3.new(0, 0, 0)
		outerStroke.Transparency = 0.2
		outerStroke.Thickness = 3
		outerStroke.Parent = frame

		-- Inner colored stroke
		local innerStroke = Instance.new("UIStroke")
		innerStroke.Color = ESP.Values["2D Box Color"] or Color3.new(0.333333, 0, 0.498039)
		innerStroke.Thickness = 1.5
		innerStroke.Parent = frame

		active2DFrames[model] = frame -- Track it
	end
end

local function update2DBoxes()
	local camera = workspace.CurrentCamera
	if not camera then return end

	for model, frame in pairs(active2DFrames) do
		if not model.Parent then
			frame.Visible = false
			continue
		end

		local humanoid = model:FindFirstChildOfClass("Humanoid")
		if not humanoid or humanoid.Health <= 0 then
			frame.Visible = false
			continue
		end

		local hrp = model:FindFirstChild("HumanoidRootPart")
		local head = model:FindFirstChild("Head")

		if not hrp or not head then
			frame.Visible = false
			continue
		end

		-- FIXED: Calculate top and bottom points based on actual character parts
		-- This prevents the "shifting" issue caused by GetBoundingBox()
		local topPos = head.Position + Vector3.new(0, head.Size.Y * 0.5 + 0.1, 0)
		local bottomPos = hrp.Position - Vector3.new(0, hrp.Size.Y * 0.5, 0)

		local topScreen = camera:WorldToViewportPoint(topPos)
		local bottomScreen = camera:WorldToViewportPoint(bottomPos)

		-- Hide if both points are behind the camera
		if topScreen.Z < 0 and bottomScreen.Z < 0 then
			frame.Visible = false
			continue
		end

		local height = math.abs(topScreen.Y - bottomScreen.Y)

		-- Hide if too far away to be visible
		if height < 5 then
			frame.Visible = false
			continue
		end

		-- FIXED: Clamp maximum height so it doesn't take up the entire screen when very close
		local maxHeight = camera.ViewportSize.Y * 0.75
		if height > maxHeight then
			height = maxHeight
		end

		-- Width is proportional to height (standard character aspect ratio)
		local width = height * 0.5 

		local centerX = (topScreen.X + bottomScreen.X) / 2
		local centerY = (topScreen.Y + bottomScreen.Y) / 2

		frame.Position = UDim2.fromOffset(centerX - width / 2, centerY - height / 2)
		frame.Size = UDim2.fromOffset(width, height)
		frame.Visible = true
	end
end

