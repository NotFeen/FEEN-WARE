			local elapsedTime = os.clock() - startTime

			-- Simulating the arrow's flight locally, now including gravity drop
			local currentArrowPos = origin + (aimVector * elapsedTime) - Vector3.new(0, 0.5 * workspace.Gravity * elapsedTime^2, 0)
			local actualTargetPos = targetPart.Position

