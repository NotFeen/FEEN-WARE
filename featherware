local miningSessions = {}

local function processPetrifiedPlayer(model)
	if not loops["auto miner"] then return end
	if activePetrifiedPlayers[model] or miningSessions[model] then return end

	local character = Player.Character
	local rootPart = character and character:FindFirstChild("HumanoidRootPart")
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not rootPart or not humanoid then return end

	local targetRoot = model:FindFirstChild("HumanoidRootPart")
	if not targetRoot then return end

	local prompt = targetRoot:FindFirstChild("MinerInteraction")
	if not prompt then return end

	local maxRange = (AutoMiner.Values and AutoMiner.Values["Range"]) or 6
	local distance = (rootPart.Position - targetRoot.Position).Magnitude

	if distance <= maxRange then
		local petrifyId = model:GetAttribute("petrifyId") 
			or model:GetAttribute("PetrifyId") 
			or prompt:GetAttribute("petrifyId")
			or prompt:GetAttribute("PetrifyId")

		if petrifyId then
			miningSessions[model] = true

			task.spawn(function()
				local animationTrack = nil
				local shouldUseAnim = AutoMiner.Values and AutoMiner.Values["Use Mine Animation"]
				local mineDuration = (AutoMiner.Values and AutoMiner.Values["Mine Duration"]) or 2.5

				-- 1. Optional Animation Setup
				if shouldUseAnim then
					local anim = Instance.new("Animation")
					anim.AnimationId = "rbxassetid://8934264605"

					local animator = humanoid:FindFirstChildOfClass("Animator") or humanoid
					animationTrack = animator:LoadAnimation(anim)
					animationTrack.Looped = true
					animationTrack:Play()
				end

				-- 2. Interruption Detection loop during the duration
				local startTime = os.clock()
				local interrupted = false

				-- Track initial state to check if they move/jump
				local initialPosition = rootPart.Position

				while os.clock() - startTime < mineDuration do
					task.wait()

					-- Check if state changed or out of range
					local currentDistance = (rootPart.Position - targetRoot.Position).Magnitude
					local hasMoved = (rootPart.Position - initialPosition).Magnitude > 0.5
					local isJumping = humanoid.FloorMaterial == Enum.Material.Air

					if not loops["auto miner"] or currentDistance > maxRange or hasMoved or isJumping then
						interrupted = true
						break
					end
				end

				-- 3. Clean up animation
				if animationTrack then
					animationTrack:Stop()
					animationTrack:Destroy()
				end

				-- 4. Fire remote if NOT interrupted
				if not interrupted then
					activePetrifiedPlayers[model] = true
					local args = {
						{
							petrifyId = petrifyId
						}
					}
					DestroyPetrifiedRemote:FireServer(unpack(args))
				end

				miningSessions[model] = nil
			end)
		end
	end
end

