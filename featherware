			shakeIntensity = AimAssist.Values["Shake Intensity"]
			shakeSpeed = AimAssist.Values["Shake Speed"]

			currentTime = os.clock() * shakeSpeed

			offsetX = math.noise(currentTime, 0, 0) * shakeIntensity
			offsetY = math.noise(0, currentTime, 0) * shakeIntensity
			offsetZ = math.noise(0, 0, currentTime) * shakeIntensity

			shakeVector = Vector3.new(offsetX, offsetY, offsetZ)

			spoofedTargetPos = targetPart.Position + shakeVector

			goalCFrame = CFrame.new(camera.CFrame.Position, spoofedTargetPos)
