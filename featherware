						task.delay(1.5, function() lostTrack:Stop() lostAnim:Destroy() end)
					end

					pcall(function()
						if PullRemote then PullRemote:FireServer({success = false}) end
					end)
				else
					if playAnims then
						local successAnim = Instance.new("Animation")
						successAnim.AnimationId = "rbxassetid://7789136489"
						local successTrack = animator:LoadAnimation(successAnim)
						successTrack:Play()
						task.delay(1.5, function() successTrack:Stop() successAnim:Destroy() end)
					end

					pcall(function()
						if PullRemote then PullRemote:FireServer({success = true}) end
					end)
				end

				if minigameApp then pcall(function() minigameApp:Destroy() end) end
				task.wait(1.2)
			else
				if idleLoopTrack then idleLoopTrack:Stop() idleLoopTrack = nil end

				pcall(function()
					if PullRemote then
						PullRemote:FireServer({success = false})
					end
				end)

				if minigameApp then pcall(function() minigameApp:Destroy() end) end
				task.wait(0.5)
			end

			isFishing = false
		end
	end
end)

local consumeAnimation = "rbxassetid://11170405197"

local function DoPaladinTP(humanoid)
	if isConsuming then
		return
	end

	isConsuming = true

	local animator = humanoid:FindFirstChildOfClass("Animator")
	if not animator then
		isConsuming = false
		return
	end

	local consumeAnim = Instance.new("Animation")
	consumeAnim.AnimationId = consumeAnimation

	local consumeTrack = animator:LoadAnimation(consumeAnim)

	consumeTrack:Play(0) 

	consumeTrack.Stopped:Wait()

	local consumeArgs = {
		{
			item = inventoriesFolder:FindFirstChild(Player.Name):FindFirstChild("scepter")
		}
	}

	game:GetService("ReplicatedStorage")
		.rbxts_include.node_modules["@rbxts"].net.out._NetManaged.ConsumeItem
		:InvokeServer(unpack(consumeArgs))
	
	task.wait(AutoLani.Values["TP Time"])
	game:GetService("ReplicatedStorage")
	["events-@easy-games/game-core:shared/game-core-networking@getEvents.Events"]
		.useAbility
		:FireServer("PALADIN_ABILITY")

	game:GetService("ReplicatedStorage")
		.rbxts_include.node_modules["@rbxts"].net.out._NetManaged.PaladinAbilityRequest
		:FireServer({
			target = game:GetService("Players"):FindFirstChild(AutoLani.Values["Player To TP"])
		})

	consumeTrack:Destroy()
	consumeAnim:Destroy()

	isConsuming = false
end

AutoLani.Callbacks.OnToggle = function(state)
	loops["auto lani"] = state

	task.spawn(function()
		while loops["auto lani"] do
			task.wait()

			if isConsuming then
				continue
			end

			if not Character then
				continue
			end

			local humanoid = Character:FindFirstChild("Humanoid")
			local handInvItem = Character:FindFirstChild("HandInvItem")

			if not humanoid or humanoid.Health <= 0 then
				continue
			end

			if not handInvItem or not handInvItem.Value then
				continue
			end

			local targetName = AutoLani.Values["Player To TP"]

			if not targetName or targetName == "" or targetName == "None" then
				continue
			end

			if handInvItem.Value.Name == "scepter" then
				DoPaladinTP(humanoid)
			end
		end
	end)
end
