HITBOX_MULTIPLIER = 4 
MAX_REACH = 30     
SPOOF_DISTANCE = 11   
originalGetTargetInRegion = sword_controller.getTargetInRegion
sword_controller.getTargetInRegion = function(self, range, chargeTime)
