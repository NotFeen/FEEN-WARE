		local function updateColor()
			local r = math.clamp(tonumber(rSlider.Text) or 255, 0, 255)
			local g = math.clamp(tonumber(gSlider.Text) or 255, 0, 255)
			local b = math.clamp(tonumber(bSlider.Text) or 255, 0, 255)
			rSlider.Text, gSlider.Text, bSlider.Text = tostring(r), tostring(g), tostring(b)

			_G.SavedConfig[settingID] = {R = r, G = g, B = b}
			saveConfigToPC()

			if cCallback then cCallback(Color3.fromRGB(r, g, b)) end
		end

		-- Color Wheel Dragging Math Engine
		local isDragging = false

		local function updateFromWheel(input)
			local rSize = wheelImage.AbsoluteSize
			local rPos = wheelImage.AbsolutePosition
			local mousePos = input.Position

			local relativeX = mousePos.X - (rPos.X + rSize.X / 2)
			local relativeY = mousePos.Y - (rPos.Y + rSize.Y / 2)

			local angle = math.atan2(relativeY, relativeX)
			local hue = (angle + math.pi) / (2 * math.pi)

			local radius = rSize.X / 2
			local distance = math.sqrt(relativeX^2 + relativeY^2)
			local saturation = math.clamp(distance / radius, 0, 1)

			if distance > radius then
				relativeX = (relativeX / distance) * radius
				relativeY = (relativeY / distance) * radius
			end

			wheelPin.Position = UDim2.new(0.5, relativeX, 0.5, relativeY)

			local pickedColor = Color3.fromHSV(hue, saturation, 1)
			rSlider.Text = tostring(math.floor(pickedColor.R * 255))
			gSlider.Text = tostring(math.floor(pickedColor.G * 255))
			bSlider.Text = tostring(math.floor(pickedColor.B * 255))

			updateColor()
		end

		-- Synchronize picker pointer position matching current configurations
		local function syncPinPosition()
			local r = tonumber(rSlider.Text) or 255
			local g = tonumber(gSlider.Text) or 255
			local b = tonumber(bSlider.Text) or 255
			local h, s, v = Color3.fromRGB(r, g, b):ToHSV()

			local angle = (h * 2 * math.pi) - math.pi
			local radius = (wheelImage.AbsoluteSize.X / 2) * s

			wheelPin.Position = UDim2.new(0.5, math.cos(angle) * radius, 0.5, math.sin(angle) * radius)
		end

		-- Input Connections
		wheelBtn.MouseButton1Click:Connect(function()
			wheelPopup.Visible = not wheelPopup.Visible
			if wheelPopup.Visible then
				syncPinPosition()
			end
		end)

		closeWheel.MouseButton1Click:Connect(function()
			wheelPopup.Visible = false
		end)

		wheelImage.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				isDragging = true
				updateFromWheel(input)
			end
		end)

		UserInputService.InputChanged:Connect(function(input)
			if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
				updateFromWheel(input)
			end
		end)

		UserInputService.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				isDragging = false
			end
		end)

		rSlider.FocusLost:Connect(updateColor)
		gSlider.FocusLost:Connect(updateColor)
		bSlider.FocusLost:Connect(updateColor)
	end
	end

