local function getItemImage(itemName)
	if not ItemMetaModule or not ItemMetaModule.getItemMeta then 
		return "" 
	end

	-- 2. Use the game's own lookup function
	-- It handles the conversion from string to Enum for you
	itemData = ItemMetaModule.getItemMeta(itemName)

	if itemData and (itemData.image or itemData.icon) then
		imgVal = itemData.image or itemData.icon

		-- Handle numeric IDs vs direct asset strings
		if type(imgVal) == "number" then
			return "rbxassetid://" .. tostring(imgVal)
		elseif type(imgVal) == "string" then
			if string.match(imgVal, "^%d+$") then
				return "rbxassetid://" .. imgVal
			end
			return imgVal
		end
	end

	return ""
end
local activeESPs = {} 

local function createChestESP(chestPart)
	billboard = Instance.new("BillboardGui")
	billboard.Name = "chestESP"
	billboard.Adornee = chestPart

	billboard.Size = UDim2.new(8.5, 0, 2.5, 0) 

	billboard.StudsOffset = Vector3.new(0, 6, 0) 
	billboard.AlwaysOnTop = true
	billboard.MaxDistance = 15000

	success, coreGui = pcall(function() return game:GetService("CoreGui") end)
	billboard.Parent = success and coreGui or Players.LocalPlayer:WaitForChild("PlayerGui")

	container = Instance.new("Frame")
	container.Name = "Container"
	container.Size = UDim2.new(1, 0, 1, 0)
	container.BackgroundTransparency = 1
	container.Parent = billboard

	layout = Instance.new("UIListLayout")
	layout.FillDirection = Enum.FillDirection.Horizontal
	layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	layout.VerticalAlignment = Enum.VerticalAlignment.Bottom
	layout.Padding = UDim.new(0, 12) 
	layout.Parent = container

	return billboard
end

local function updateChestESP(billboard, inventoryFolder)
	container = billboard:FindFirstChild("Container")
	if not container then return end

	currentItems = {}
	for _, obj in pairs(inventoryFolder:GetChildren()) do
		if obj.Name ~= "ChestOwner" then
			table.insert(currentItems, obj.Name)
		end
	end

	table.sort(currentItems)
	local inventoryHash = table.concat(currentItems, ",")

	if billboard:GetAttribute("LastHash") == inventoryHash then
		return 
	end

	billboard:SetAttribute("LastHash", inventoryHash)

	for _, child in pairs(container:GetChildren()) do
		if child:IsA("ImageLabel") then
			child:Destroy()
		end
	end

	for _, itemName in ipairs(currentItems) do
		img = Instance.new("ImageLabel")

		img.Size = UDim2.new(2, 0, 2, 0) 
		img.SizeConstraint = Enum.SizeConstraint.RelativeYY 
		img.BackgroundTransparency = 1
		img.Image = getItemImage(itemName)
		img.BorderSizePixel = 0


		img.Parent = container
	end
end

