local function generateRandomString(length)
	local chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
	local result = ""
	for i = 1, length do
		local rand = math.random(1, #chars)
		result = result .. string.sub(chars, rand, rand)
	end
	return result
end

local function checkVoidAhead(rootPart)
	local launchDirection = rootPart.CFrame.LookVector.Unit
	local rayOrigin = rootPart.Position + (launchDirection * 3.5)
	local rayDirection = Vector3.new(0, -15, 0)

	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	params.FilterDescendantsInstances = {rootPart.Parent}

	local result = workspace:Raycast(rayOrigin, rayDirection, params)
	return result == nil
end

