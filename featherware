local activeESP = {}
local active2DFrames = {} -- Cache for our 2D Box frames
local renderConnection = nil

-- Setup a ScreenGui to hold the 2D boxes
local espGui = Instance.new("ScreenGui")
espGui.Name = "AdminESP_GUI"
espGui.IgnoreGuiInset = true
espGui.Parent = Player:WaitForChild("PlayerGui") -- Put in PlayerGui (or CoreGui if your admin panel has access)

local function clearESP(model)
	if activeESP[model] then
		for _, instance in pairs(activeESP[model]) do
			if instance then instance:Destroy() end
		end
		activeESP[model] = nil
	end

	if active2DFrames[model] then
		active2DFrames[model]:Destroy()
		active2DFrames[model] = nil
	end
end

local function applyESP(model, isNPC)
	local espOnOwn = ESP.Values["ESP On Own Player"]
	local espOnNPCs = ESP.Values["ESP On NPCs"]
	local isOwnPlayer = (model == Player.Character)

	if isOwnPlayer and not espOnOwn then return end
	if isNPC and not espOnNPCs then return end
	if not isNPC and isOwnPlayer == false then return end

	clearESP(model)
	activeESP[model] = {}

	-- 1. Chams
	if ESP.Values["Chams"] then
		local highlight = Instance.new("Highlight")
		-- Added safety fallback color here:
		highlight.FillColor = ESP.Values["Chams Color"] or Color3.new(0.333333, 0, 0.498039)
		highlight.FillTransparency = 0.5 
		highlight.OutlineColor = Color3.new(1, 1, 1)
		highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		highlight.Parent = model
		table.insert(activeESP[model], highlight)
	end

	-- 2. 3D Box
	if ESP.Values["3D Box"] then
		local box = Instance.new("SelectionBox")
		box.LineThickness = 0.05

		-- Added safety fallback color here:
		local boxColor = ESP.Values["3D Box Color"] or Color3.new(0.333333, 0, 0.498039)
		box.Color3 = boxColor
		box.SurfaceColor3 = boxColor

		box.Transparency = 0.7 
		box.Adornee = model
		box.Parent = model
		table.insert(activeESP[model], box)
	end

	-- 3. 2D Box Setup
	if ESP.Values["2D Box"] then
		local frame = Instance.new("Frame")
		frame.BackgroundTransparency = 1 
		frame.Size = UDim2.new(0, 0, 0, 0)
		frame.Visible = false
		frame.Parent = espGui

		local stroke = Instance.new("UIStroke")
		-- Added safety fallback color here:
		stroke.Color = ESP.Values["2D Box Color"] or Color3.new(0.333333, 0, 0.498039)
		stroke.Thickness = 1.5
		stroke.Parent = frame

		active2DFrames[model] = frame
	end
end

local function update2DBoxes()
	for model, frame in pairs(active2DFrames) do
		if model and model.PrimaryPart then
			local cframe, size = model:GetBoundingBox()

			local top = cframe.Position + Vector3.new(0, size.Y / 2, 0)
			local bottom = cframe.Position - Vector3.new(0, size.Y / 2, 0)

			local topScreen, topOnScreen = workspace.CurrentCamera:WorldToViewportPoint(top)
			local bottomScreen, bottomOnScreen = workspace.CurrentCamera:WorldToViewportPoint(bottom)

			if topOnScreen or bottomOnScreen then
				local height = math.abs(bottomScreen.Y - topScreen.Y)
				local width = height / 1.5 

				frame.Size = UDim2.new(0, width, 0, height)
				frame.Position = UDim2.new(0, topScreen.X - (width / 2), 0, topScreen.Y)
				frame.Visible = true
			else
				frame.Visible = false
			end
		else
			frame.Visible = false
		end
	end
end

local function refreshAllESP()
	for _, player in pairs(Players:GetPlayers()) do
		if player.Character and player.Character:FindFirstChild("Humanoid") and player.Character.PrimaryPart then
			applyESP(player.Character, false)
		end
	end

	for _, npc in pairs(workspace:GetChildren()) do
		if npc and npc:IsA("Model") and npc:FindFirstChild("Humanoid") and npc.PrimaryPart then
			if not Players:GetPlayerFromCharacter(npc) then
				applyESP(npc, true)
			end
		end
	end
end

local function cleanAllESP()
	for model, _ in pairs(activeESP) do clearESP(model) end
	for model, _ in pairs(active2DFrames) do clearESP(model) end
	activeESP = {}
	active2DFrames = {}
end

