	game.Debris:AddItem(tracer, travelTime)
end


local function isPathClear(origin, targetPos, ignoreList)
	local raycastParams = RaycastParams.new()
	raycastParams.FilterDescendantsInstances = ignoreList
	raycastParams.FilterType = Enum.RaycastFilterType.Exclude
	raycastParams.RespectCanCollide = true 

	local direction = targetPos - origin
	local result = workspace:Raycast(origin, direction, raycastParams)
	return result == nil 
end

local function getFiringSolution(origin, targetStartPos, targetVelocity, projectileSpeed)
	gravity = workspace.Gravity
	predictedPos = targetStartPos
	timeOfFlight = 0
	angle = 0

	-- Iterate to refine the predicted position based on flight time
	for i = 1, 4 do
		predictedPos = targetStartPos + (targetVelocity * timeOfFlight)

		local diff = predictedPos - origin
		local horizontalDist = Vector2.new(diff.X, diff.Z).Magnitude
		local verticalDist = diff.Y

		local v2 = projectileSpeed ^ 2
		local v4 = projectileSpeed ^ 4
		local root = v4 - gravity * (gravity * horizontalDist^2 + 2 * verticalDist * v2)

		-- Target is mathematically out of range
		if root < 0 then
			return nil, nil, nil 
		end

		-- Calculate the lower trajectory arc angle
		angle = math.atan2(v2 - math.sqrt(root), gravity * horizontalDist)

		local horizontalVelocity = projectileSpeed * math.cos(angle)
		timeOfFlight = horizontalDist / horizontalVelocity
	end

	-- Create the final 3D directional velocity vector
	local diff = predictedPos - origin
	local dir = Vector3.new(diff.X, 0, diff.Z).Unit

	local aimVector = dir * (projectileSpeed * math.cos(angle))
	aimVector = aimVector + Vector3.new(0, projectileSpeed * math.sin(angle), 0)

	return aimVector, predictedPos, timeOfFlight
end


local function hasLineOfSight(originPart, targetPart, playerCharacter)
	if not originPart or not targetPart then return false end
	local origin = originPart.Position
	local targetPos = targetPart.Position
	local direction = targetPos - origin

	local raycastOrigin = origin + (direction.Unit * 2.5)
	local raycastDirection = targetPos - raycastOrigin

	local raycastParams = RaycastParams.new()
	raycastParams.FilterDescendantsInstances = {playerCharacter, targetPart.Parent}
	raycastParams.FilterType = Enum.RaycastFilterType.Exclude
	raycastParams.RespectCanCollide = true 

	local raycastResult = workspace:Raycast(raycastOrigin, raycastDirection, raycastParams)
	return raycastResult == nil
end


local function fireProjectile(projectileName, HRP, targetPart, itemRequired, target)
	local origin = HRP.Position
	if not targetPart or not Player.Character then return end

	local targetHumanoid = target:FindFirstChild("Humanoid")
	if not targetHumanoid or targetHumanoid.Health <= 0 then return end	

	handItemName = tostring(itemRequired)
	speed = WeaponSpeeds[handItemName] or 150
	initialDistance = (targetPart.Position - origin).Magnitude

	if initialDistance < 8 then
		origin = origin + (HRP.CFrame.LookVector * 1.5)
	end

	predictedPos = targetPart.Position
	flightTime = 0
	aimVector = Vector3.zero

	-- NEW MATH IMPLEMENTATION
	if speed < 9999 then
		local velocity = targetPart.AssemblyLinearVelocity or Vector3.zero

		-- Call the gravity-compensating function
		local calculatedAim, calcPos, calcTime = getFiringSolution(origin, targetPart.Position, velocity, speed)

		if not calculatedAim then
			return false -- Target is completely out of range, abort shot
		end

		aimVector = calculatedAim
		predictedPos = calcPos
		flightTime = calcTime + 0.05 -- Adding a tiny buffer for network latency

		if not isPathClear(origin, predictedPos, {Player.Character, target}) then
			local alternatePos = predictedPos + Vector3.new(0, 1.5, 0)
			if isPathClear(origin, alternatePos, {Player.Character, target}) then
				predictedPos = alternatePos
			else
				return false 
			end
		end
	else
		-- Fallback for hitscan/instant weapons (speed >= 9999)
		flightTime = initialDistance / 150
		local directionVector = (predictedPos - origin).Unit
		aimVector = directionVector * 150
	end

	if targetPart.Name == "Head" then
