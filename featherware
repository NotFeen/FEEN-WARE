local function applyTracer(obj, isPreview)
	if not isPreview and not VALID_PROJECTILES[obj.Name] then return end

	task.spawn(function()
		local handle = obj:FindFirstChild("Handle") or obj
		if not handle then return end

		local function getEffect(target, className)
			if target:IsA(className) then return target end
			return target:FindFirstChildWhichIsA(className)
		end

		trail = getEffect(obj, "Trail") or getEffect(handle, "Trail")
		beam = getEffect(obj, "Beam") or getEffect(handle, "Beam")
		particle = getEffect(obj, "ParticleEmitter") or getEffect(handle, "ParticleEmitter")

		if trail then
			colorVal = ProjectileTracers.Values["Color"]

			if typeof(colorVal) == "Color3" and colorVal.R == 0 and colorVal.G == 0 and colorVal.B == 0 then
				trail.Texture = "rbxassetid://446111719" 
				trail.Color = ColorSequence.new(Color3.fromRGB(255, 255, 255)) 
				trail.Transparency = NumberSequence.new(0) 
				trail.LightEmission = 0 
				trail.LightInfluence = 1 
			else
				local colorSeq = typeof(colorVal) == "Color3" and ColorSequence.new(colorVal) or colorVal
				trail.Color = colorSeq
				trail.Texture = "" 
				trail.LightEmission = ProjectileTracers.Values["Glow"] and ProjectileTracers.Values["Glow Intensity"] or 0
			end
		end

		if beam then
			local widthVal = ProjectileTracers.Values["Width"]
			local colorVal = ProjectileTracers.Values["Color"]

			if typeof(widthVal) == "number" then
				local success = pcall(function()
					beam.Width0 = widthVal
					beam.Width1 = widthVal * 0.5
				end)
				if not success then
					beam.Width0 = NumberSequence.new(widthVal)
					beam.Width1 = NumberSequence.new(widthVal * 0.5)
				end
			elseif typeof(widthVal) == "NumberSequence" then
				beam.Transparency = widthVal
				pcall(function() 
					beam.Width0 = widthVal 
					beam.Width1 = widthVal 
				end)
			end

			local colorSeq = typeof(colorVal) == "Color3" and ColorSequence.new(colorVal) or colorVal
			beam.Color = colorSeq

			beam.LightEmission = ProjectileTracers.Values["Glow"] and ProjectileTracers.Values["Glow Intensity"] or 0
		end

		if particle then
			local colorVal = ProjectileTracers.Values["Color"]
			particle.Color = typeof(colorVal) == "ColorSequence" and colorVal.Keypoints[1].Color or colorVal

			if ProjectileTracers.Values["Glow"] then
				particle.LightEmission = ProjectileTracers.Values["Glow Intensity"]
			end
		end

		if not isPreview then
			for _, descendant in pairs(obj:GetDescendants()) do
				if descendant:IsA("BasePart") and descendant.Name ~= "HumanoidRootPart" then
					local nameLower = descendant.Name:lower()
					if descendant == handle or nameLower:find("arrow") or nameLower:find("projectile") or nameLower:find("bolt") then
						local colorVal = ProjectileTracers.Values["Color"]
						descendant.Color = typeof(colorVal) == "ColorSequence" and colorVal.Keypoints[1].Color or colorVal

						if ProjectileTracers.Values["Glow"] then
							descendant.Material = Enum.Material.Neon
						end
					end
				end
			end
		end
	end)
end


