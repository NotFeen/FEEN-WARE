disableCurrentAnimations = function(char)
	if not char then return end
	local animate = char:FindFirstChild("Animate")
	if animate then
		animate.Disabled = true
	end
	local hum = char:FindFirstChildOfClass("Humanoid")
	if not hum then return end
	local animator = hum:FindFirstChildOfClass("Animator")
	if animator then
		for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
			track:Stop(0)
		end
	end
end


AnimationSwitch = GameTab:CreateButton("Animation Switch", nil, true)

AnimationSwitch:CreateToggle("Disable Animations", function(state)
	loops["animation switch"] = state

	if loops["animation switch"] then
		disableCurrentAnimations(character)

		local hum = character:FindFirstChildOfClass("Humanoid")
		if hum then
			animConnection = hum.AnimationPlayed:Connect(function(track)
				track:Stop(0)
			end)
		end

	else
		if animConnection then
			animConnection:Disconnect()
			animConnection = nil
		end


		if cachedHumanoid then
			local animator = cachedHumanoid:FindFirstChild("Animator")
			if animator then
				for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
					track:Play() -- Use :Play(), not :Start()
				end
			end
		end

	end
end, false)

