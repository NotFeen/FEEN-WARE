			connection:Disconnect() 
		end
	end
	connections = {}

	-- Hard clear all active graphical elements
	for model, _ in pairs(activeESP) do clearESP(model) end
	for model, _ in pairs(active2DFrames) do clearESP(model) end
	activeESP = {}
	active2DFrames = {}
end

ESP.Callbacks.OnToggle = function(state)
	loops["esp"] = state

	if loops["esp"] then
		refreshAllESP()

		local lastESPUpdate = 0

		connections["RenderStepped"] = RunService.RenderStepped:Connect(function()
			local now = os.clock()

			-- Changed from 0.033 to 0.016 for smoother 60FPS tracking
			if now - lastESPUpdate < 0.016 then
				return
			end

			lastESPUpdate = now
			update2DBoxes()
		end)

		local function hookPlayer(p)
			connections[p.Name .. "_charAdded"] = p.CharacterAdded:Connect(function(char)
				char:WaitForChild("HumanoidRootPart", 5)
				if loops["esp"] then applyESP(char, false) end
			end)
			connections[p.Name .. "_charRemoving"] = p.CharacterRemoving:Connect(function(char)
				clearESP(char)
			end)
		end

		for _, p in pairs(Players:GetPlayers()) do hookPlayer(p) end
		connections["PlayerAdded"] = Players.PlayerAdded:Connect(hookPlayer)

		connections["PlayerRemoving"] = Players.PlayerRemoving:Connect(function(p)
			if p.Character then clearESP(p.Character) end
			if connections[p.Name .. "_charAdded"] then connections[p.Name .. "_charAdded"]:Disconnect() end
			if connections[p.Name .. "_charRemoving"] then connections[p.Name .. "_charRemoving"]:Disconnect() end
		end)

