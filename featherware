local function disableCurrentAnimations(char)
	if not char then return end

	local animate = char:FindFirstChild("Animate")
	if animate then
		animate.Disabled = true
	end

	-- 2. NOW stop the tracks on the client
	local hum = char:FindFirstChildOfClass("Humanoid")
	if not hum then return end

	local animator = hum:FindFirstChildOfClass("Animator")
	if animator then
		for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
			track:Stop(0)
		end
	end
end

function NotificationSystem.Notify(title, text, duration)
	local cfg = NotificationSystem.Settings

	if not cfg.Enabled then return end

	duration = duration or cfg.Lifetime

	local frame = Instance.new("Frame")
	frame.Size = UDim2.new(0, cfg.Width, 0, cfg.Height)
	frame.BackgroundColor3 = cfg.BackgroundColor
	frame.BorderSizePixel = 0
	frame.ClipsDescendants = true -- Keeps the accent line safely inside the rounded corners
	frame.Parent = holder

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 8) -- Changed to 8 (slightly sharper, modern look)
	corner.Parent = frame

	-- NEW: Modern subtle outline (UIStroke)
	local stroke = Instance.new("UIStroke")
	stroke.Color = Color3.fromRGB(255, 255, 255)
	stroke.Transparency = 0.85 -- Barely visible, gives a glassy/premium edge
	stroke.Thickness = 1.2
	stroke.Parent = frame

	-- NEW: Subtle lighting gradient for depth
	local gradient = Instance.new("UIGradient")
	gradient.Rotation = 45
	gradient.Transparency = NumberSequence.new{
		NumberSequenceKeypoint.new(0, 0),
		NumberSequenceKeypoint.new(1, 0.15)
	}
	gradient.Parent = frame

	-- NEW: Colored Accent Bar on the left side
	local accent = Instance.new("Frame")
	accent.Size = UDim2.new(0, 4, 1, 0)
	accent.BackgroundColor3 = cfg.TitleColor -- Automatically matches your title color
	accent.BorderSizePixel = 0
	accent.Parent = frame

	local titleLbl = Instance.new("TextLabel")
	titleLbl.Parent = frame
	titleLbl.BackgroundTransparency = 1
	titleLbl.Position = UDim2.new(0, 16, 0, 8) -- Shifted slightly to make room for the accent
	titleLbl.Size = UDim2.new(1, -24, 0, 20)
	titleLbl.Text = tostring(title)
	titleLbl.TextColor3 = cfg.TitleColor
	titleLbl.Font = Enum.Font.GothamBold
	titleLbl.TextSize = 15 
	titleLbl.TextXAlignment = Enum.TextXAlignment.Left

	local textLbl = Instance.new("TextLabel")
	textLbl.Parent = frame
	textLbl.BackgroundTransparency = 1
	textLbl.Position = UDim2.new(0, 16, 0, 30)
	textLbl.Size = UDim2.new(1, -24, 1, -38)
	textLbl.Text = tostring(text)
	textLbl.TextColor3 = cfg.TextColor
	textLbl.Font = Enum.Font.GothamMedium -- Upgraded to Medium for better readability
	textLbl.TextSize = 13
	textLbl.TextWrapped = true
	textLbl.RichText = true -- Allows you to use <b>bold</b> or colors in your notification text!
	textLbl.TextXAlignment = Enum.TextXAlignment.Left
	textLbl.TextYAlignment = Enum.TextYAlignment.Top -- Prevents small text from floating weirdly in the middle

	frame.Position = UDim2.new(1, 400, 0, 0)

	TweenService:Create(frame, cfg.SlideTween, {
		Position = UDim2.new(0, 0, 0, 0)
	}):Play()

	task.delay(duration, function()
		local tween = TweenService:Create(frame, cfg.FadeTween, {
			BackgroundTransparency = 1,
			Position = UDim2.new(1, 400, 0, 0)
		})

		tween:Play()

		-- UPGRADED FADE OUT: Now smoothly fades the text, the new outline, and the accent bar!
		for _, v in ipairs(frame:GetDescendants()) do
			if v:IsA("TextLabel") then
				TweenService:Create(v, cfg.FadeTween, { TextTransparency = 1 }):Play()
			elseif v:IsA("UIStroke") then
				TweenService:Create(v, cfg.FadeTween, { Transparency = 1 }):Play()
			elseif v:IsA("Frame") then
				TweenService:Create(v, cfg.FadeTween, { BackgroundTransparency = 1 }):Play()
			end
		end

		tween.Completed:Wait()
		frame:Destroy()
	end)
end

