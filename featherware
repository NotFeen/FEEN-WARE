	local function generateId()
		local characters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
		local id = ""
		for i = 1, 8 do
			local randomIndex = math.random(1, #characters)
			id = id .. string.sub(characters, randomIndex, randomIndex)
		end
		return id
	end

