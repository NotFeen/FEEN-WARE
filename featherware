				local now = os.clock()
				local cooldown = tonumber(InfJump.Values["Jump Cooldown"]) or 0.1

				if now - lastJumpTime >= cooldown then

					if now - lastJumpTime < (cooldown + 1.0) then
						consecutiveJumps = consecutiveJumps + 1
					else
						consecutiveJumps = 0
					end
					lastJumpTime = now

					local nativePower = humanoid.UseJumpPower and humanoid.JumpPower or 50
					local accelPower = consecutiveJumps * tonumber(InfJump.Values["Jump Accel (per jump)"])
					local finalPower = nativePower + accelPower

					if InfJump.Values["Bypass Jump Limits"] then
						humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
					end

					hrp.AssemblyLinearVelocity = Vector3.new(
						hrp.AssemblyLinearVelocity.X, 
						finalPower, 
						hrp.AssemblyLinearVelocity.Z
					)
				end
			end
		else
			consecutiveJumps = 0
		end
	end)

