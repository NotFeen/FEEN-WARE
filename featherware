-- ==========================================
-- 2. BYPASS DISTANCE CHECK & SPOOF SERVER
-- ==========================================
-- The game cancels hits if you are too far away. This hooks the attack function to 
-- temporarily spoof your position to the server so it accepts the hit from further away.
originalAttackEntity = sword_controller.attackEntity
sword_controller.attackEntity = function(self, entity, rayDirection, chargedAttack, options)
	if entity then
		instance = entity.getInstance and entity:getInstance()
		myChar = Player.Character

		if instance and instance.PrimaryPart and myChar and myChar.PrimaryPart then
			dist = (myChar.PrimaryPart.Position - instance.PrimaryPart.Position).Magnitude

			-- If the target is outside normal range but inside our expanded hitbox
			if dist > 12 and dist <= MAX_REACH then
				loriginalCFrame = myChar:GetPivot()
				targetPos = instance.PrimaryPart.Position
				direction = (targetPos - myChar.PrimaryPart.Position).Unit

				-- Calculate a spoofed position that is within the server's accepted range
				spoofedPos = targetPos - (direction * SPOOF_DISTANCE)

				-- Temporarily move the character to trick the client and server distance checks
				myChar:PivotTo(CFrame.new(spoofedPos) * originalCFrame.Rotation)

				-- Call the original function (this will also send the spoofed position to the server)
				result = originalAttackEntity(self, entity, rayDirection, chargedAttack, options)

				-- Instantly revert to the real position so you don't actually teleport
				myChar:PivotTo(originalCFrame)

				return result
			end
		end
	end

	return originalAttackEntity(self, entity, rayDirection, chargedAttack, options)
end

